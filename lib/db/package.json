{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "push": "drizzle-kit generate:pg --config ../../lib/db/drizzle.config.ts",
    "push-force": "drizzle-kit generate:pg --config ../../lib/db/drizzle.config.ts --force",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "sqlite3": "^6.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.7",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}